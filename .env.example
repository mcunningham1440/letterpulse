# Django
SECRET_KEY=your-secret-key-here

# Optional: dedicated key for encrypting per-user Beehiiv tokens
# (analytics/fields.py:EncryptedCharField). Falls back to SECRET_KEY when
# unset. Set this to the current SECRET_KEY value before ever rotating
# SECRET_KEY, otherwise SECRET_KEY rotation will permanently corrupt all
# stored Beehiiv tokens.
# BEEHIIV_TOKEN_ENCRYPTION_KEY=your-token-encryption-key

# API Keys
OPENAI_API_KEY=your-openai-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# Aurora database - Dev
DB_HOST=letterpulse-dev.cluster-xxxxx.us-east-1.rds.amazonaws.com
DATABASE_SECRET={"username":"your_db_user","password":"your_db_password"}
# DB_NAME defaults to "letterpulse" if unset. Set to override.
# DB_NAME=letterpulse

# Public hostnames per deployment target (comma-separated).
# 127.0.0.1 and localhost are always allowed implicitly.
# ALLOWED_HOSTS=letterpulse.com,xxxxxxxxxx.us-east-1.awsapprunner.com
# CSRF_TRUSTED_ORIGINS=https://letterpulse.com,https://xxxxxxxxxx.us-east-1.awsapprunner.com
